# Build context: fake_job_detector/
# Used by: api/Dockerfile, spark/Dockerfile, kafka/Dockerfile

# Python runtime artifacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environments
venv/
.venv/
env/
ENV/

# Test and coverage artifacts
.pytest_cache/
htmlcov/
.coverage
*.egg-info/

# IDE and OS
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Local environment files — secrets must not enter the image
.env
.env.local
.env.*.local

# Next.js dashboard (not needed for Python service images)
dashboard/node_modules/
dashboard/.next/
dashboard/.pnpm-store/

# Spark / ML output dirs (mounted as volumes at runtime)
output/

# Jupyter
.ipynb_checkpoints/

# Git
.git/
.gitignore
