# =============================================================================
# Fake Job Detector — Environment Configuration
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_DB=fake_jobs_db
POSTGRES_USER=fraud_user
# REQUIRED: set a strong password before running docker compose
POSTGRES_PASSWORD=change_me_strong_password

# -----------------------------------------------------------------------------
# Kafka (KRaft mode — no Zookeeper)
# -----------------------------------------------------------------------------
KAFKA_JOBS_TOPIC=jobs
KAFKA_PROCESSED_TOPIC=processed_jobs
KAFKA_CONSUMER_GROUP=spark_jobs_stream

# -----------------------------------------------------------------------------
# Spark
# -----------------------------------------------------------------------------
# local[*] = single-machine (default for local dev)
# spark://spark-master:7077 = standalone cluster (set by docker-compose automatically)
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_TRIGGER_INTERVAL=5 seconds
SPARK_MAX_OFFSETS_PER_TRIGGER=700
ENABLE_PROCESSED_TOPIC=false
# Anomaly detection tuning
ANOMALY_EMA_ALPHA=0.2
ANOMALY_SPIKE_MULTIPLIER=2.2
ANOMALY_RATE_MULTIPLIER=1.8
ANOMALY_RATE_THRESHOLD=0.55

# -----------------------------------------------------------------------------
# FastAPI
# -----------------------------------------------------------------------------
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000
API_DB_POOL_MIN=1
API_DB_POOL_MAX=10
API_WS_INTERVAL_SECONDS=1.0
API_LOG_LEVEL=INFO
SPARK_DOWN_LAG_THRESHOLD=2000

# -----------------------------------------------------------------------------
# Next.js Dashboard
# NOTE: NEXT_PUBLIC_* vars are embedded at BUILD time.
# For Docker the browser always reaches the API via the host port-forward.
# Change these only if you expose the API on a different host/port.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
DASHBOARD_PORT=3000

# -----------------------------------------------------------------------------
# Producer (docker compose --profile producer up)
# -----------------------------------------------------------------------------
REPLAY_SPEED=10.0
MAX_KAFKA_LAG=5000
LAG_CHECK_EVERY=50
PRODUCER_MAX_MESSAGES=
